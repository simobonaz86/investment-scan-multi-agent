INVEST_SCAN_DB_PATH=data/app.db
INVEST_SCAN_HTTP_TIMEOUT_SECONDS=12
INVEST_SCAN_MAX_CONCURRENT_FETCHES=12
INVEST_SCAN_CACHE_TTL_SECONDS=300
INVEST_SCAN_MAX_NEWS_ITEMS=8

# Automated scanning (scheduler)
INVEST_SCAN_AUTOSCAN_ENABLED=false
INVEST_SCAN_AUTOSCAN_INTERVAL_SECONDS=300
INVEST_SCAN_AUTOSCAN_TICKERS_CSV=AAPL,MSFT
INVEST_SCAN_AUTOSCAN_ONLY_MARKET_HOURS=true
INVEST_SCAN_MARKET_TIMEZONE=America/New_York
INVEST_SCAN_MARKET_OPEN_HHMM=09:30
INVEST_SCAN_MARKET_CLOSE_HHMM=16:00

## Universe + rankings
INVEST_SCAN_UNIVERSE_SOURCE=sp500_datahub_csv
INVEST_SCAN_UNIVERSE_DATAHUB_CSV_URL=https://datahub.io/core/s-and-p-500-companies/r/constituents.csv
INVEST_SCAN_UNIVERSE_REFRESH_SECONDS=86400
INVEST_SCAN_UNIVERSE_MAX_TICKERS=500

# Optional: fetch universe directly from Yahoo Finance predefined screeners.
# Set INVEST_SCAN_UNIVERSE_SOURCE=yahoo_screener and choose one:
# - most_actives
# - day_gainers
# - day_losers
# INVEST_SCAN_UNIVERSE_YAHOO_SCREENER_ID=most_actives
# INVEST_SCAN_UNIVERSE_YAHOO_SCREENER_COUNT=250

# Ticker discovery: pick a dynamic subset of the universe to scan.
# This lets the app "find tickers" first (from Yahoo screeners) and then run the full scan pipeline.
# INVEST_SCAN_TICKER_DISCOVERY_ENABLED=true
# INVEST_SCAN_TICKER_DISCOVERY_SCREENER_IDS_CSV=most_actives,day_gainers
# INVEST_SCAN_TICKER_DISCOVERY_COUNT_PER_SCREENER=250
# INVEST_SCAN_TICKER_DISCOVERY_MAX_TICKERS=200

# S&P 500 rolling weekly ranking (works any day; uses last 5 trading days)
INVEST_SCAN_SP500_WEEKLY_RANKING_ENABLED=true
INVEST_SCAN_SP500_RANKING_MAX_TICKERS=200

# Market-wide scan (auto candidate finder)
INVEST_SCAN_MARKETSCAN_ENABLED=true
INVEST_SCAN_MARKETSCAN_INTERVAL_SECONDS=1800
INVEST_SCAN_MARKETSCAN_ONLY_MARKET_HOURS=true
INVEST_SCAN_MARKETSCAN_TOP_N=25
INVEST_SCAN_MARKETSCAN_MIN_SCORE=5

# Position sizing (trade plan)
INVEST_SCAN_RISK_PER_TRADE_PCT=0.01
INVEST_SCAN_STOP_ATR_MULTIPLE=2.0
INVEST_SCAN_MIN_POSITION_USD=100

# Optional fallback market-data provider (used if yfinance/Yahoo is rate-limited or blocked)
# INVEST_SCAN_FINNHUB_API_KEY=your_key_here

# Intraday watchlist triggers (Stage 2)
# INVEST_SCAN_INTRADAY_ENABLED=true
# INVEST_SCAN_INTRADAY_ONLY_MARKET_HOURS=true
# INVEST_SCAN_INTRADAY_INTERVAL=15m
# INVEST_SCAN_INTRADAY_PERIOD=5d
# INVEST_SCAN_INTRADAY_WATCHLIST_SIZE=20
# INVEST_SCAN_INTRADAY_POLL_SECONDS=180

